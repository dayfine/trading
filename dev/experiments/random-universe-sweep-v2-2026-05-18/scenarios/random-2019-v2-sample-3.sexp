((name "random-2019-v2-sample-3")
 (description "Random 500-symbol sample 3 from delisted-aware top-3000-2019 pool (seed 55), 2019-01-02 → 2023-12-29. P6 follow-up to #1180.")
 (period ((start_date 2019-01-02) (end_date 2023-12-29)))
 (universe_path "universes/random-2019-v2-delisted-aware/sample-3.sexp")
 (universe_size 500)
 (config_overrides
  (((portfolio_config ((max_position_pct_long 0.14))))
   ((portfolio_config ((max_long_exposure_pct 0.70))))
   ((portfolio_config ((min_cash_pct 0.30))))
   ((enable_stage3_force_exit true))
   ((stage3_force_exit_config ((hysteresis_weeks 1))))
   ((enable_laggard_rotation true))
   ((laggard_rotation_config ((hysteresis_weeks 2))))))
 (expected
  ((total_return_pct ((min -200.0) (max 1000.0)))
   (total_trades ((min 0) (max 5000)))
   (win_rate ((min 0.0) (max 100.0)))
   (sharpe_ratio ((min -10.0) (max 10.0)))
   (max_drawdown_pct ((min 0.0) (max 100.0)))
   (avg_holding_days ((min 0.0) (max 500.0)))
   (open_positions_value ((min 0.0) (max 100000000.0)))
   (sortino_ratio_annualized ((min -10.0) (max 10.0)))
   (calmar_ratio ((min -10.0) (max 10.0)))
   (ulcer_index ((min 0.0) (max 100.0)))
   (wall_seconds ((min 1.0) (max 3600.0))))))
