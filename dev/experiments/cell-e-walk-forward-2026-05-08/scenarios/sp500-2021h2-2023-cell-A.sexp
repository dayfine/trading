;; Walk-forward A — 2.5y sp500 second half (2021-07..2023-12)
((name "sp500-2021h2-2023-cell-A")
 (description "2.5y sp500 second half (2021-07..2023-12) Cell A")
 (period ((start_date 2021-07-01) (end_date 2023-12-29))) (universe_path "universes/sp500.sexp")
 (universe_size 500)
 (config_overrides ())
 (expected
  ((total_return_pct   ((min -100.0) (max 500.0)))
   (total_trades       ((min   0)    (max 1000)))
   (win_rate           ((min   0.0)  (max 100.0)))
   (sharpe_ratio       ((min  -2.0)  (max   3.0)))
   (max_drawdown_pct   ((min   0.0)  (max  90.0)))
   (avg_holding_days   ((min   0.0)  (max 500.0)))
   (open_positions_value ((min 0.0)  (max 50000000.0))))))
