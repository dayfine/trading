;; Walk-forward E — 3y bull-crash first half (2015-2017)
((name "bull-crash-2015-2017-cell-E")
 (description "3y bull-crash first half (2015-2017) Cell E")
 (period ((start_date 2015-01-02) (end_date 2017-12-29)))
 (universe_size 302)
 (config_overrides (((enable_stage3_force_exit true))
   ((stage3_force_exit_config ((hysteresis_weeks 1))))
   ((enable_laggard_rotation true))
   ((laggard_rotation_config ((hysteresis_weeks 2))))))
 (expected
  ((total_return_pct   ((min -100.0) (max 500.0)))
   (total_trades       ((min   0)    (max 1000)))
   (win_rate           ((min   0.0)  (max 100.0)))
   (sharpe_ratio       ((min  -2.0)  (max   3.0)))
   (max_drawdown_pct   ((min   0.0)  (max  90.0)))
   (avg_holding_days   ((min   0.0)  (max 500.0)))
   (open_positions_value ((min 0.0)  (max 50000000.0))))))
